rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Business Profiles Collection
    match /business_profiles/{profileName} {
      // Allow unrestricted read for public access to the landing page
      allow read: if true;
      
      // Allow CRUD operations for sandbox playground and admin setup
      allow write: if true;
    }
  }
}
