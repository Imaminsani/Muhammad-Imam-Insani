# Kunci API Layanan Cerdas Gemini AI (Server-Side Secret)
GEMINI_API_KEY=your_gemini_api_key_here

# Konfigurasi Koneksi Database Utama (Opsional - Berupa MySQL)
# Jika dikonfigurasi, sistem akan menyimpan profil ke MySQL secara real-time.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=wisma_bidara_db
